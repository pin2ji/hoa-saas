<%- include('layouts/main') %>
<h1>किरायेदार डैशबोर्ड</h1>
<p>स्वागत है, <%%= tenant.name %></p>
<%% if (tenant.lease) { %>
  <p>मासिक किराया: ₹<%%= tenant.lease.rentAmount %></p>
  <a href="/tenant/pay-rent">अभी किराया भरें</a>
<%% } else { %>
  <p>कोई सक्रिय लीज़ नहीं।</p>
<%% } %>
<h3>पिछले भुगतान</h3>
<ul>
<%% payments.forEach(p => { %>
  <li>₹<%%= p.amount %> - <%%= p.date.toDateString() %> - <%%= p.status %></li>
<%% }) %>
</ul>
<h3>नोटिस</h3>
<%% notices.forEach(n => { %>
  <p><%%= n.message %> (दिनांक: <%%= n.sentAt.toDateString() %>)</p>
<%% }) %>
<a href="/auth/logout">लॉगआउट</a>
