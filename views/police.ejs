<%- include('layouts/main') %>
<h2>नज़दीकी पुलिस थाना खोजें</h2>
<input type="text" id="locationInput" placeholder="पिन कोड या इलाका डालें">
<button onclick="searchPolice()">खोजें</button>
<iframe id="mapFrame" width="100%" height="500" style="border:0;" loading="lazy"></iframe>
<script>
function searchPolice() {
  var loc = document.getElementById('locationInput').value;
  var url = "https://www.google.com/maps/embed/v1/search?key=YOUR_GOOGLE_MAPS_API_KEY&q=police+station+near+" + encodeURIComponent(loc);
  document.getElementById('mapFrame').src = url;
}
</script>
